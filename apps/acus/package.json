{
  "name": "acus",
  "version": "0.1.0",
  "private": true,
  "description": "AmberCon US site",
  "license": "MIT",
  "author": "guy@wyrdrune.com",
  "files": [],
  "type": "module",
  "scripts": {
    "analyze": "ANALYZE=true pnpm build",
    "boot": "DB_ENV=acus pnpm -F server db:migrate:up && DB_ENV=acus pnpm -F @amber/server prisma:generate && DB_ENV=acus pnpm -F amber boot ",
    "build": "pnpm boot && pnpm next:build",
    "next:build": "NODE_ENV=production next build",
    "db:dump": "DB_ENV=acus pnpm -F server db:dump",
    "db:import": "DB_ENV=acus pnpm -F server db:import",
    "db:restore": "DB_ENV=acus pnpm -F server db:restore",
    "dev": "pnpm boot && NODE_OPTIONS=--max_old_space_size=4096 next dev -p 30001",
    "dev:test": "pnpm test:setup && NODE_ENV=test NODE_OPTIONS=--max_old_space_size=4096 next dev -p 30003",
    "start": "next start",
    "tsc": "tsc -p ./tsconfig.json",
    "test:setup": "DB_ENV=acus dotenv -e .env.test -- pnpm -F server db:cleanTestSeed",
    "test:e2e": "playwright test",
    "test:e2e:update": "playwright test --update-snapshots",
    "test:e2e:coverage": "PLAYWRIGHT_COVERAGE=1 playwright test"
  },
  "dependencies": {
    "@amber/amber": "workspace:*",
    "@amber/client": "workspace:*",
    "@amber/environment": "workspace:*",
    "@amber/playwright": "workspace:*",
    "@amber/server": "workspace:*",
    "@amber/shared": "workspace:*",
    "@amber/ui": "workspace:*",
    "@auth0/nextjs-auth0": "4.21.0",
    "@emotion/react": "^11.14.0",
    "@emotion/server": "^11.11.0",
    "@emotion/styled": "^11.14.1",
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/mdx": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@mui/icons-material": "^9.2.0",
    "@mui/material": "^9.2.0",
    "@mui/system": "^9.2.0",
    "@mui/x-date-pickers": "^9.8.0",
    "@next/mdx": "^16.2.10",
    "@prisma/client": "^7.8.0",
    "@stripe/react-stripe-js": "^6.4.0",
    "@stripe/stripe-js": "^9.6.0",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/table-core": "8.21.3",
    "@trpc/server": "^11.18.0",
    "debug": "4.4.3",
    "email-templates": "^13.0.1",
    "formik": "^2.4.9",
    "jose": "^6.2.3",
    "luxon": "^3.7.2",
    "micro-cors": "^0.1.1",
    "next": "16.2.6",
    "pg": "^8.22.0",
    "pug": "^3.0.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "remark-frontmatter": "^5.0.0",
    "remark-mdx-frontmatter": "^5.2.0",
    "stripe": "^22.1.1",
    "yup": "^1.7.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@amber/tsconfig": "workspace:*",
    "@babel/core": "^7.29.7",
    "@babel/helper-regex": "^7.10.5",
    "@babel/plugin-syntax-flow": "^7.29.7",
    "@babel/plugin-transform-react-jsx": "^7.29.7",
    "@babel/preset-react": "^7.29.7",
    "@next/bundle-analyzer": "^16.2.10",
    "@playwright/test": "^1.61.1",
    "@types/debug": "4.1.13",
    "@types/luxon": "^3.7.2",
    "@types/mdx": "^2.0.14",
    "@types/micro-cors": "^0.1.6",
    "@types/node": "^25.9.5",
    "@types/pug": "^2.0.10",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript/native": "npm:typescript@^7.0.2",
    "baseline-browser-mapping": "^2.10.42",
    "bufferutil": "4.1.0",
    "node-fetch": "^3.3.2",
    "typescript": "npm:@typescript/typescript6@^6.0.2",
    "utf-8-validate": "6.0.6",
    "webpack": "^5.108.4"
  },
  "browserslist": [
    ">0.5%",
    "not dead",
    "not ie 11",
    "not op_mini all"
  ]
}
